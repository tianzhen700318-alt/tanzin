version: '3.8'

services:
  line-bot:
    build: .
    container_name: line-bot-appointment
    restart: unless-stopped
    ports:
      - "8000:8000"
    environment:
      - LINE_CHANNEL_SECRET=${LINE_CHANNEL_SECRET}
      - LINE_CHANNEL_ACCESS_TOKEN=${LINE_CHANNEL_ACCESS_TOKEN}
      - ADMIN_USER_IDS=${ADMIN_USER_IDS}
      - PORT=8000
    env_file:
      - .env
    volumes:
      - ./data:/app/data  # 如果需要持久化資料，可以掛載
    networks:
      - line-bot-network

networks:
  line-bot-network:
    driver: bridge
